# ============================================================
# SISTEMA KURVE — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# NUNCA commitees el .env.local con valores reales.
# ============================================================

# --- Supabase ---
# Dashboard → Settings → API
# URL del proyecto (pública, segura para el browser)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anónima (pública, segura para el browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service role (SECRETA — solo backend, nunca exponer al browser)
# Se usa para crear usuarios en Auth desde las API routes admin
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (emails automáticos) ---
# Resend → API Keys → Create API Key (permiso: Sending access)
RESEND_API_KEY=

# Dirección desde la que salen los emails del sistema
# Debe ser del dominio verificado en Resend (sin dominio verificado usar: onboarding@resend.dev)
RESEND_FROM_EMAIL=noreply@notificaciones.kurve.ar

# Email del administrador que recibe notificaciones del sistema (ej: nuevas correcciones)
ADMIN_EMAIL=kurvedevelops@gmail.com

# Secret para autenticar el cron de Vercel en /api/reminders/send
# Generá un string random seguro (ej: openssl rand -base64 32)
CRON_SECRET=

# --- WhatsApp vía Twilio (feature en evaluación, puede no estar activa) ---
# Twilio → Console → Account Info
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886